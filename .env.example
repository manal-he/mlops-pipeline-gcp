# GCP Configuration
PROJECT_ID=mlops-pipeline-prod
REGION=europe-west1
DATASET_ID=ml_data

# Cloud Storage
ARTIFACTS_BUCKET=${PROJECT_ID}-mlops-artifacts
MODEL_URI=gs://${ARTIFACTS_BUCKET}/models/latest/

# Service Account
SA_EMAIL=mlops-pipeline-sa@${PROJECT_ID}.iam.gserviceaccount.com

# Cloud Run
SERVICE_NAME=ml-prediction-api

# Pipeline
PIPELINE_NAME=mlops-training-pipeline
PIPELINE_ROOT=gs://${ARTIFACTS_BUCKET}/pipeline-root/

# Model Configuration
MODEL_TYPE=xgboost
TARGET_COLUMN=is_churned
BASELINE_F1=0.75
IMPROVEMENT_THRESHOLD=0.01
